# =================================================================
# CryptoWatch Pro — environment variables
# Copy this to `.env.local` for local dev, or set them in Vercel.
# Never commit a real `.env.local`. The server is the only consumer
# of any secret-bearing variable — the browser only sees the
# `NEXT_PUBLIC_*` ones.
# =================================================================

# ----- Supabase (DB + Auth) -----
# Public — exposed to the browser for the Supabase client.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# Server-only. NEVER expose this to the client. Lets API routes bypass
# RLS for trusted operations (cron jobs, AI proxy).
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# ----- AI (Anthropic) -----
# Used server-side only by /api/ai-insight. Never put this in a
# NEXT_PUBLIC_* variable.
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: switch models without redeploying code
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# ----- Email (Resend) -----
# Used by the /api/check-alerts cron route to email users who aren't
# online when an alert fires. Free tier is fine for low volume.
RESEND_API_KEY="re_..."
ALERT_FROM_EMAIL="alerts@yourdomain.com"

# ----- App config -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: a Vercel-provided protection secret. Vercel populates
# this for you; only set manually for self-hosted cron workers.
CRON_SECRET=""
